# ==============================
# shorts-engine environment file
# Copy to .env and fill values
# ==============================

# ---------- Runtime ----------
PYTHON_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Paris

# ---------- Project paths ----------
PROJECT_ROOT=.
LOGS_DIR=./logs
OUTPUTS_DIR=./outputs
PROMPTS_DIR=./prompts

# ---------- Gemini (Google Generative AI) ----------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT_SEC=60

# ---------- LTX-2.3 local video generation ----------
LTX_MODEL_ID=Lightricks/LTX-Video-2.3
LTX_DEVICE=cuda
LTX_DTYPE=float16
LTX_NUM_INFERENCE_STEPS=30
LTX_GUIDANCE_SCALE=6.5
LTX_SEED=42
LTX_FPS=24
LTX_WIDTH=1080
LTX_HEIGHT=1920
LTX_MAX_SCENE_SEC=10
LTX_NEGATIVE_PROMPT=blurry, low resolution, watermark, text artifacts, flicker, frame jitter

# ---------- Visual coherence / image conditioning ----------
ENABLE_IMAGE_CONDITIONING=true
REFERENCE_IMAGE_PATH=
CONDITIONING_STRENGTH=0.6

# ---------- Audio (Kokoro local fallback / Voxtral-ready) ----------
AUDIO_BACKEND=kokoro
KOKORO_VOICE=fr_female_default
KOKORO_SPEED=1.0
KOKORO_SAMPLE_RATE=24000
KOKORO_DEVICE=cuda

# Voxtral placeholder (future swap)
VOXTRAL_API_KEY=
VOXTRAL_MODEL=

# ---------- FFmpeg ----------
# Leave empty if ffmpeg is available in PATH
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFMPEG_THREADS=0
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
OUTPUT_CRF=20
OUTPUT_PRESET=medium
OUTPUT_AUDIO_BITRATE=192k

# ---------- Trends: Google Trends + Reddit ----------
PYTRENDS_HL=fr-FR
PYTRENDS_TZ=60
PYTRENDS_GEO=FR
PYTRENDS_CAT=0

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=shorts-engine/1.0 by your_reddit_username
REDDIT_SUBREDDITS=artificial,MachineLearning,singularity,histoire,france

# ---------- YouTube Data API v3 ----------
YOUTUBE_CLIENT_SECRETS_FILE=./secrets/client_secret.json
YOUTUBE_TOKEN_FILE=./secrets/youtube_token.json
YOUTUBE_CHANNEL_ID=
YOUTUBE_CATEGORY_ID=27
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_NOTIFY_SUBSCRIBERS=false

# ---------- Scheduling ----------
SCHEDULER_ENABLED=true
SCHEDULER_MAX_WORKERS=4
SCHEDULER_MISFIRE_GRACE_SEC=300
SCHEDULER_COALESCE=true

# ---------- Dashboard ----------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_RELOAD=false

# ---------- Pipeline behavior ----------
MAX_SHORT_DURATION_SEC=60
MIN_SHORT_DURATION_SEC=50
MAX_SCENES=8
DEFAULT_LANGUAGE=fr
AUTO_UPLOAD=false
KEEP_INTERMEDIATE_FILES=true
