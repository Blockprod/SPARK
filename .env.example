# ==============================
# shorts-engine environment file
# Copy to .env and fill values
# ==============================

# ---------- Runtime ----------
PYTHON_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Paris

# ---------- Project paths ----------
PROJECT_ROOT=.
LOGS_DIR=./logs
OUTPUTS_DIR=./outputs
PROMPTS_DIR=./prompts

# ---------- Gemini (Google Generative AI) ----------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT_SEC=60

# ---------- LTX-Video, Kokoro, FFmpeg, PyTrends : configurés dans config.yaml ----------
# Ces modules lisent exclusivement config.yaml. Les variables LTX_*, KOKORO_*,
# FFMPEG_*, PYTRENDS_* ne sont PAS lues par le code. Modifier config.yaml.

# Voxtral placeholder (future swap)
VOXTRAL_API_KEY=
VOXTRAL_MODEL=

# ---------- FFmpeg : configuré dans config.yaml (section post_production) ----------
# FFMPEG_BIN, FFPROBE_BIN, VIDEO_CODEC, OUTPUT_CRF etc. ne sont pas lus depuis .env.
# Si ffmpeg n'est pas dans PATH, définir ffmpeg_bin dans config.yaml.

# ---------- Trends: Google Trends + Reddit ----------
# PYTRENDS_HL/TZ/GEO/CAT et REDDIT_SUBREDDITS sont configurés dans config.yaml.
# Seules les clés d'API Reddit ci-dessous sont lues depuis .env.

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=shorts-engine/1.0 by your_reddit_username

# ---------- YouTube Data API v3 ----------
YOUTUBE_CLIENT_SECRETS_FILE=./secrets/client_secret.json
YOUTUBE_TOKEN_FILE=./secrets/youtube_token.json
YOUTUBE_CHANNEL_ID=
YOUTUBE_CATEGORY_ID=28
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_NOTIFY_SUBSCRIBERS=false
# Encrypt the OAuth2 token at rest — generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ---------- Scheduling ----------
SCHEDULER_ENABLED=true
SCHEDULER_MAX_WORKERS=4
SCHEDULER_MISFIRE_GRACE_SEC=300
SCHEDULER_COALESCE=true

# ---------- Dashboard ----------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_RELOAD=false
DASHBOARD_API_KEY=your_secret_api_key_here
DASHBOARD_CORS_ORIGINS=http://localhost:7860

# ---------- Pipeline behavior ----------
MAX_SHORT_DURATION_SEC=60
MIN_SHORT_DURATION_SEC=50
MAX_SCENES=8
DEFAULT_LANGUAGE=fr
AUTO_UPLOAD=false
KEEP_INTERMEDIATE_FILES=true
